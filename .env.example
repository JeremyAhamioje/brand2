# Copy to .env and fill in. These are read server-side only.
# Do NOT prefix with VITE_ — that would expose them to the browser.

# Resend API key (https://resend.com → API Keys)
RESEND_API_KEY=

# Where lead emails are delivered
LEAD_TO_EMAIL=you@example.com

# Verified sender. Defaults to Resend's onboarding@resend.dev if unset,
# which only delivers to your own Resend account email.
LEAD_FROM_EMAIL=Managed Leads <onboarding@resend.dev>
